{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "declaration": true,
    "jsx": "react",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "paths": {
      "@jam/core": ["../core/src/index.ts"],
      "@jam/core/*": ["../core/src/*"],
      "@jam/ui": ["../jamagui/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "../core/src/jsx-types.d.ts"]
}
